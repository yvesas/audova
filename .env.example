# Copy to .env and fill in. NEVER commit the real .env (it is gitignored).
# See .claude/rules/security-and-privacy.md

# --- Transcription engine ---
STT_PROVIDER=groq                 # groq | openai | local
GROQ_API_KEY=
OPENAI_API_KEY=
LOCAL_WHISPER_URL=http://local-whisper:9000

# --- Infra ---
DATABASE_URL=postgres://audova:audova@db:5432/audova
REDIS_URL=                        # optional in the MVP
AUDIO_TMP_DIR=/data/audio
AUDIO_TTL_HOURS=24

# --- Auth (NextAuth) — used from Phase 3 ---
NEXTAUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Quotas (see docs/07-monetizacao.md) ---
QUOTA_ANON_MIN_PER_DAY=60
QUOTA_FREE_MIN_PER_MONTH=600
